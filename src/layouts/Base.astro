---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'PreACT 9 Vocabulary Flashcards' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Categorized flashcards for PreACT 9 Secure: test terms and high-frequency academic words, with click-to-hear pronunciation." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
