---
import Base from '../../layouts/Base.astro';
import { SUBJECT_META } from '../../data/vocab';
import { buildPlan, TOTAL_DAYS } from '../../data/plan';

export function getStaticPaths() {
  const plan = buildPlan();
  return plan.map((d) => ({
    params: { day: String(d.day) },
    props: { day: d },
  }));
}

const { day } = Astro.props;
const dayNum = day.day;
const prevDay = dayNum > 1 ? dayNum - 1 : null;
const nextDay = dayNum < TOTAL_DAYS ? dayNum + 1 : null;

// Subjects that actually have words today.
const activeSubjects = day.subjects.filter((s) => s.words.length > 0);
const totalQuestions = activeSubjects.reduce((n, s) => n + s.quiz.length, 0);

// Serialize quiz for the client.
const quizData = activeSubjects.map((s) => ({
  subject: s.subject,
  accent: SUBJECT_META[s.subject].accent,
  label: SUBJECT_META[s.subject].label,
  words: s.words.map((w) => ({
    word: w.word,
    definition: w.definition,
    example: w.example,
  })),
  quiz: s.quiz,
}));

// Flatten today's words (across subjects) into one swipeable flashcard deck,
// same one-word-at-a-time pattern as the homepage deck.
const flashDeck = quizData.flatMap((s) =>
  s.words.map((w) => ({
    ...w,
    subject: s.subject,
    accent: s.accent,
    subjectLabel: s.label,
  }))
);
---

<Base title={`PreACT 9 — Day ${dayNum}`}>
  <main class="mx-auto max-w-3xl px-4 py-6 sm:py-8">
    <header class="mb-6">
      <div class="flex items-center justify-between gap-3">
        <a href="/plan" class="text-sm text-[var(--muted)] transition hover:text-[var(--text)]">
          ← All days
        </a>
        <div class="flex gap-2">
          {prevDay && (
            <a href={`/plan/${prevDay}`} class="rounded-full border border-[var(--line)] px-3 py-1 text-sm text-[var(--muted)] transition hover:text-[var(--text)]">
              ← Day {prevDay}
            </a>
          )}
          {nextDay && (
            <a href={`/plan/${nextDay}`} class="rounded-full border border-[var(--line)] px-3 py-1 text-sm text-[var(--muted)] transition hover:text-[var(--text)]">
              Day {nextDay} →
            </a>
          )}
        </div>
      </div>
      <h1 class="mt-3 text-2xl font-bold sm:text-3xl">Day {dayNum}</h1>
      <p class="mt-1 text-sm text-[var(--muted)]">
        Step 1: study the words. Step 2: take the quiz ({totalQuestions} questions).
      </p>
    </header>

    <!-- STEP 1 — Study cards (one word at a time, swipe left/right) -->
    <section class="mb-8">
      <div class="mb-3 flex items-center justify-between text-sm text-[var(--muted)]">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--muted)]">
          Step 1 · Study today's words
        </h2>
        <div class="flex items-center gap-3">
          <span id="flash-position">1 / {flashDeck.length}</span>
          <button
            id="flash-replay-btn"
            type="button"
            class="inline-flex items-center gap-1.5 rounded-full border border-[var(--line)] px-3 py-1 transition hover:text-[var(--text)]"
            aria-label="Hear it again"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 5 6 9H2v6h4l5 4z" />
              <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
              <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
            </svg>
            Hear it
          </button>
        </div>
      </div>

      <div class="relative flex items-stretch">
        <button
          id="flash-prev"
          type="button"
          class="nav-arrow absolute left-0 top-1/2 z-10 -translate-y-1/2 -translate-x-1 rounded-full border border-[var(--line)] bg-[var(--surface)] p-2 text-[var(--muted)] transition hover:text-[var(--text)] disabled:opacity-30 sm:-translate-x-4"
          aria-label="Previous word"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
        </button>

        <div id="flash-stage" class="flex w-full touch-pan-y select-none flex-col">
          <article
            id="flash-card"
            class="flex min-h-[16rem] flex-1 flex-col rounded-3xl border border-[var(--line)] bg-[var(--surface)] p-7 sm:p-9"
          >
            <p id="flash-subject" class="text-[11px] font-semibold uppercase tracking-wider"></p>
            <h3 id="flash-word" class="mt-2 text-3xl font-bold sm:text-4xl"></h3>

            <button
              id="flash-reveal-btn"
              type="button"
              class="mt-4 w-fit rounded-full border border-[var(--line)] px-3 py-1 text-xs font-semibold text-[var(--muted)] transition hover:text-[var(--text)]"
              aria-pressed="false"
            >
              Show definition
            </button>

            <div id="flash-answer" class="hidden">
              <p class="mt-6 text-[11px] font-semibold uppercase tracking-wider text-[var(--muted)]">Meaning</p>
              <p id="flash-def" class="mt-1 text-base leading-relaxed"></p>

              <p class="mt-5 text-[11px] font-semibold uppercase tracking-wider text-[var(--muted)]">Example</p>
              <p id="flash-ex" class="mt-1 text-[15px] italic leading-relaxed text-[var(--muted)]"></p>
            </div>
          </article>
        </div>

        <button
          id="flash-next"
          type="button"
          class="nav-arrow absolute right-0 top-1/2 z-10 -translate-y-1/2 translate-x-1 rounded-full border border-[var(--line)] bg-[var(--surface)] p-2 text-[var(--muted)] transition hover:text-[var(--text)] disabled:opacity-30 sm:translate-x-4"
          aria-label="Next word"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
        </button>
      </div>

      <p id="flash-audio-hint" class="mt-3 text-center text-xs text-[var(--muted)]">
        Tap anywhere once to enable read-aloud.
      </p>
    </section>

    <!-- STEP 2 — Quiz -->
    <section>
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--muted)]">
          Step 2 · Quiz
        </h2>
        <span id="score-live" class="text-sm text-[var(--muted)]">
          Score: <span id="score">0</span> / {totalQuestions}
        </span>
      </div>
      <div id="quiz-root"></div>

      <div id="day-result" class="mt-6 hidden rounded-2xl border border-[var(--line)] bg-[var(--surface-2)] p-5 text-center">
        <p class="text-lg font-bold">Day {dayNum} complete</p>
        <p id="result-line" class="mt-1 text-sm text-[var(--muted)]"></p>
        {nextDay && (
          <a href={`/plan/${nextDay}`} class="mt-4 inline-block rounded-full bg-[var(--text)] px-5 py-2 text-sm font-semibold text-[var(--bg)]">
            Continue to Day {nextDay} →
          </a>
        )}
      </div>
    </section>
  </main>

  <style is:global>
    /* Global: quiz choice buttons are created via document.createElement in the
       script below, so Astro's scoped-style attribute never lands on them —
       scoped rules here would silently never match. */
    .choice.is-correct { border-color:#2faf6a; background:#2faf6a18; }
    .choice.is-correct .choice-key { border-color:#2faf6a; background:#2faf6a; color:#ffffff; }
    .choice.is-wrong { border-color:#e23a6e; background:#e23a6e18; }
    .choice.is-wrong .choice-key { border-color:#e23a6e; background:#e23a6e; color:#ffffff; }
    .q.answered .choice:not(.is-correct):not(.is-wrong) { opacity:.5; }
    .slide-from-right {
      animation: slideFromRight 0.28s cubic-bezier(0.4, 0.2, 0.2, 1);
    }
    .slide-from-left {
      animation: slideFromLeft 0.28s cubic-bezier(0.4, 0.2, 0.2, 1);
    }
    @keyframes slideFromRight {
      from { transform: translateX(28px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    @keyframes slideFromLeft {
      from { transform: translateX(-28px); opacity: 0; }
      to { transform: translateX(0); opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .slide-from-right, .slide-from-left { animation: none; }
    }
  </style>

  <script define:vars={{ quizData, dayNum, totalQuestions, flashDeck }}>
    // --- Speech (reuse the same natural-voice picker as the flashcards) ---
    const synth = window.speechSynthesis;
    let cachedVoice = null;
    const PREFERRED = ['Samantha','Ava','Allison','Susan','Karen','Serena','Google US English','Google UK English Female','Microsoft Aria','Microsoft Jenny','Microsoft Zira'];
    const NOVELTY = /bad news|good news|bahh|bells|boing|bubbles|cellos|jester|organ|superstar|trinoids|wobble|zarvox|whisper|albert|fred|ralph|junior|kathy|grandma|grandpa|reed|rocko|sandy|shelley|flo|eddy|deranged|hysterical|pipe|princess/i;
    function pickVoice() {
      if (!synth) return null;
      if (cachedVoice) return cachedVoice;
      const voices = synth.getVoices();
      if (!voices.length) return null;
      const en = (v) => /^en/i.test(v.lang);
      for (const name of PREFERRED) {
        const v = voices.find((vo) => en(vo) && vo.name.toLowerCase().includes(name.toLowerCase()));
        if (v) return (cachedVoice = v);
      }
      const f = voices.find((v) => en(v) && /female|woman|aria|jenny|zira|serena|samantha|ava|allison/i.test(v.name) && !NOVELTY.test(v.name));
      if (f) return (cachedVoice = f);
      return (cachedVoice = voices.find((v) => /en[-_]US/i.test(v.lang) && !NOVELTY.test(v.name)) || voices.find((v) => en(v) && !NOVELTY.test(v.name)) || null);
    }
    if (synth) { synth.onvoiceschanged = () => synth.getVoices(); synth.getVoices(); }
    function speak(word) {
      if (!synth || !word) return;
      synth.cancel();
      const u = new SpeechSynthesisUtterance(word);
      u.lang = 'en-US'; u.rate = 0.9; u.pitch = 1.05;
      const v = pickVoice(); if (v) { u.voice = v; u.lang = v.lang; }
      synth.speak(u);
    }

    // --- Flashcard viewer (Step 1): one word at a time, swipe/arrows ----
    const flashCards = flashDeck;
    let flashIndex = 0;
    let flashAudioUnlocked = false;

    const flashStage = document.getElementById('flash-stage');
    const flashCardEl = document.getElementById('flash-card');
    const flashSubjectEl = document.getElementById('flash-subject');
    const flashWordEl = document.getElementById('flash-word');
    const flashDefEl = document.getElementById('flash-def');
    const flashExEl = document.getElementById('flash-ex');
    const flashPosEl = document.getElementById('flash-position');
    const flashPrevBtn = document.getElementById('flash-prev');
    const flashNextBtn = document.getElementById('flash-next');
    const flashReplayBtn = document.getElementById('flash-replay-btn');
    const flashAudioHint = document.getElementById('flash-audio-hint');
    const flashRevealBtn = document.getElementById('flash-reveal-btn');
    const flashAnswerBox = document.getElementById('flash-answer');

    // Hidden by default on every new card so the word alone can be tested
    // before checking the meaning.
    let flashRevealed = false;
    function updateFlashReveal() {
      flashAnswerBox.classList.toggle('hidden', !flashRevealed);
      flashRevealBtn.textContent = flashRevealed ? 'Hide definition' : 'Show definition';
      flashRevealBtn.setAttribute('aria-pressed', String(flashRevealed));
    }
    if (flashRevealBtn) {
      flashRevealBtn.addEventListener('click', () => {
        flashRevealed = !flashRevealed;
        updateFlashReveal();
      });
    }

    function speakFlashCurrent() {
      const card = flashCards[flashIndex];
      if (flashAudioUnlocked && card) speak(card.word);
    }

    function renderFlash(animateDir) {
      const card = flashCards[flashIndex];
      if (!card) return;
      flashCardEl.style.borderColor = `${card.accent}55`;
      flashSubjectEl.textContent = card.subjectLabel;
      flashSubjectEl.style.color = card.accent;
      flashWordEl.textContent = card.word;
      flashWordEl.style.color = card.accent;
      flashDefEl.textContent = card.definition;
      flashExEl.textContent = `"${card.example}"`;
      flashPosEl.textContent = `${flashIndex + 1} / ${flashCards.length}`;

      flashPrevBtn.disabled = flashIndex === 0;
      flashNextBtn.disabled = flashIndex === flashCards.length - 1;

      flashRevealed = false;
      updateFlashReveal();

      if (animateDir) {
        flashStage.classList.remove('slide-from-left', 'slide-from-right');
        void flashStage.offsetWidth;
        flashStage.classList.add(
          animateDir === 'next' ? 'slide-from-right' : 'slide-from-left'
        );
      }
      speakFlashCurrent();
    }

    function goFlash(delta) {
      const next = flashIndex + delta;
      if (next < 0 || next >= flashCards.length) return;
      flashIndex = next;
      renderFlash(delta > 0 ? 'next' : 'prev');
    }

    function unlockFlashAudio() {
      if (flashAudioUnlocked) return;
      flashAudioUnlocked = true;
      // Use visibility (not display:none) so the hint's space stays reserved —
      // collapsing it here would shift the whole quiz section up by its height
      // at the exact moment between a real click's mousedown and mouseup,
      // making that first click land on the wrong element.
      if (flashAudioHint) flashAudioHint.style.visibility = 'hidden';
      speakFlashCurrent();
    }

    if (flashCards.length) {
      flashPrevBtn.addEventListener('click', () => goFlash(-1));
      flashNextBtn.addEventListener('click', () => goFlash(1));
      flashReplayBtn.addEventListener('click', () => {
        flashAudioUnlocked = true;
        if (flashAudioHint) flashAudioHint.style.visibility = 'hidden';
        speak(flashCards[flashIndex]?.word);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') goFlash(1);
        else if (e.key === 'ArrowLeft') goFlash(-1);
      });

      let flashStartX = 0;
      let flashStartY = 0;
      let flashTracking = false;
      flashStage.addEventListener(
        'touchstart',
        (e) => {
          const t = e.changedTouches[0];
          flashStartX = t.clientX;
          flashStartY = t.clientY;
          flashTracking = true;
        },
        { passive: true }
      );
      flashStage.addEventListener(
        'touchend',
        (e) => {
          if (!flashTracking) return;
          flashTracking = false;
          const t = e.changedTouches[0];
          const dx = t.clientX - flashStartX;
          const dy = t.clientY - flashStartY;
          if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.5) {
            goFlash(dx < 0 ? 1 : -1);
          }
        },
        { passive: true }
      );

      window.addEventListener('pointerdown', unlockFlashAudio, { once: true });
      window.addEventListener('keydown', unlockFlashAudio, { once: true });

      renderFlash();
      flashAudioUnlocked = true;
      speakFlashCurrent();
      flashAudioUnlocked = false;
    }

    // --- Render quiz ---
    const root = document.getElementById('quiz-root');
    const scoreEl = document.getElementById('score');
    let score = 0;
    let answered = 0;

    for (const s of quizData) {
      const section = document.createElement('div');
      section.className = 'mb-6';
      const head = document.createElement('p');
      head.className = 'mb-2 text-[11px] font-semibold uppercase tracking-wider';
      head.style.color = s.accent;
      head.textContent = `${s.label} · ${s.quiz.length} questions`;
      section.appendChild(head);

      s.quiz.forEach((item, qi) => {
        const q = document.createElement('div');
        q.className = 'q mb-3 rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-4';
        q.dataset.answer = item.answer;

        const prompt = document.createElement('p');
        prompt.className = 'font-medium leading-relaxed whitespace-pre-line';
        prompt.textContent = item.prompt;
        q.appendChild(prompt);

        const choicesWrap = document.createElement('div');
        choicesWrap.className = 'mt-3 space-y-2';
        item.choices.forEach((c) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'choice flex w-full items-start gap-3 rounded-xl border border-[var(--line)] px-4 py-2.5 text-left text-sm transition hover:border-[var(--muted)]';
          btn.dataset.choice = c.id;
          btn.innerHTML = `<span class="choice-key mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[var(--line)] text-[11px] font-semibold">${c.id}</span><span></span>`;
          btn.querySelector('span:last-child').textContent = c.text;
          btn.addEventListener('click', () => {
            if (q.classList.contains('answered')) return;
            q.classList.add('answered');
            answered++;
            if (c.id === item.answer) { btn.classList.add('is-correct'); score++; }
            else {
              btn.classList.add('is-wrong');
              const right = [...q.querySelectorAll('.choice')].find((x) => x.dataset.choice === item.answer);
              right?.classList.add('is-correct');
            }
            scoreEl.textContent = String(score);
            saveProgress(false);
            if (answered === totalQuestions) finish();
          });
          choicesWrap.appendChild(btn);
        });
        q.appendChild(choicesWrap);
        section.appendChild(q);
      });
      root.appendChild(section);
    }

    function saveProgress(done) {
      try {
        localStorage.setItem(`preact9:day:${dayNum}`, JSON.stringify({ done, score, total: totalQuestions }));
      } catch {}
    }
    function finish() {
      saveProgress(true);
      const pct = Math.round((score / totalQuestions) * 100);
      document.getElementById('result-line').textContent = `You scored ${score} of ${totalQuestions} (${pct}%).`;
      document.getElementById('day-result').classList.remove('hidden');
      document.getElementById('day-result').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    // Restore prior score display (does not re-lock answers; a fresh attempt starts clean).
    try {
      const prev = JSON.parse(localStorage.getItem(`preact9:day:${dayNum}`) || 'null');
      if (prev && prev.done) {
        document.getElementById('result-line').textContent = `Last time: ${prev.score} of ${prev.total}. Retake below to improve.`;
        document.getElementById('day-result').classList.remove('hidden');
      }
    } catch {}
  </script>
</Base>
