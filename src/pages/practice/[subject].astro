---
import Base from '../../layouts/Base.astro';
import { SUBJECTS, SUBJECT_META } from '../../data/vocab';
import { PRACTICE_BY_SUBJECT } from '../../data/practice';
import type { Choice } from '../../data/practice';

function processPassage(passage: string | undefined, prompt: string, choices: Choice[]): string {
  if (!passage) return '';

  let underlineText: string | null = null;

  // Pattern 1: underlined phrase/sentence/text/word/verb phrase/portion "quoted text"
  const m1 = prompt.match(/underlined (?:phrase|sentence|text|word|verb phrase|portion)[^"]*"([^"]+)"/);
  if (m1) underlineText = m1[1];

  // Pattern 2: [BLANK] + choice A is "NO CHANGE (actual word)"
  if (!underlineText && prompt.includes('[BLANK]')) {
    const choiceA = choices.find((c) => c.id === 'A');
    if (choiceA) {
      const m = choiceA.text.match(/NO CHANGE\s*\(([^)]+)\)/i);
      if (m) underlineText = m[1];
    }
  }

  // Pattern 3: last quoted phrase in prompt that appears verbatim in the passage
  if (!underlineText) {
    const allQuoted = [...prompt.matchAll(/"([^"[\]]+)"/g)];
    for (let i = allQuoted.length - 1; i >= 0; i--) {
      const candidate = allQuoted[i][1];
      if (passage.includes(candidate) && candidate.length > 4) {
        underlineText = candidate;
        break;
      }
    }
  }

  let html = passage;
  if (underlineText) {
    const esc = underlineText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    html = html.replace(new RegExp(esc), (m) => `<u class="passage-u">${m}</u>`);
  }
  return html.replace(/\n/g, '<br>');
}

// One page per subject. Only subjects that actually have questions are built.
export function getStaticPaths() {
  return SUBJECTS.filter((s) => PRACTICE_BY_SUBJECT[s].length > 0).map((s) => ({
    params: { subject: s.toLowerCase() },
    props: { subject: s },
  }));
}

const { subject } = Astro.props;
const meta = SUBJECT_META[subject];
const questions = PRACTICE_BY_SUBJECT[subject];
---

<Base title={`PreACT 9 Practice — ${meta.label}`}>
  <main class="mx-auto max-w-3xl px-4 py-6 sm:py-8" data-subject={subject.toLowerCase()}>
    <header class="mb-6">
      <div class="flex items-baseline justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--muted)]">
            PreACT 9 Practice
          </p>
          <h1 class="mt-1 flex items-center gap-3 text-2xl font-bold sm:text-3xl">
            <span
              class="rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider"
              style={`background:${meta.accent}22;color:${meta.accent}`}
            >
              {meta.label}
            </span>
          </h1>
        </div>
        <a
          href="/practice"
          class="shrink-0 rounded-full border border-[var(--line)] px-4 py-1.5 text-sm font-medium text-[var(--muted)] transition hover:text-[var(--text)]"
        >
          ← All sections
        </a>
      </div>
      <p class="mt-2 text-sm text-[var(--muted)]">
        <span id="progress">0</span> of {questions.length} answered ·
        Score: <span id="score">0</span>
      </p>
    </header>

    <div
      id="cooldown-banner"
      class="hidden mb-6 rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-5 text-center"
    >
      <p class="font-semibold text-[var(--text)]">Test locked</p>
      <p class="mt-1 text-sm text-[var(--muted)]">
        Retake available in <span id="cooldown-time" class="font-medium text-[var(--text)]"></span>
      </p>
    </div>

    <ol class="space-y-6">
      {
        questions.map((q, i) => (
          <li
            class="question rounded-2xl border border-[var(--line)] bg-[var(--surface)] p-5"
            data-answer={q.answer}
          >
            {q.passage && (
              <p
                class="passage mb-4 rounded-xl border border-[var(--line)] bg-[var(--surface-2)] p-4 text-sm leading-relaxed text-[var(--muted)]"
                set:html={processPassage(q.passage, q.prompt, q.choices)}
              />
            )}
            <p class="font-medium leading-relaxed">
              <span class="mr-1 text-[var(--muted)]">{i + 1}.</span>
              {q.prompt}
            </p>
            <div class="mt-4 space-y-2">
              {q.choices.map((c) => (
                <button
                  type="button"
                  class="choice flex w-full items-start gap-3 rounded-xl border border-[var(--line)] px-4 py-3 text-left text-sm transition hover:border-[var(--muted)]"
                  data-choice={c.id}
                  style={`--accent:${meta.accent}`}
                >
                  <span class="choice-key mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-[var(--line)] text-[11px] font-semibold">
                    {c.id}
                  </span>
                  <span>{c.text}</span>
                </button>
              ))}
            </div>
            {q.explanation && (
              <p class="explanation mt-3 hidden rounded-xl bg-[var(--surface-2)] p-3 text-sm leading-relaxed text-[var(--muted)]">
                {q.explanation}
              </p>
            )}
          </li>
        ))
      }
    </ol>

    <div class="mt-8 flex items-center justify-between border-t border-[var(--line)] pt-5">
      <a href="/practice" class="text-sm text-[var(--muted)] transition hover:text-[var(--text)]">
        ← Back to all sections
      </a>
      <div class="flex items-center gap-3">
        <button
          id="submit-btn"
          type="button"
          class="hidden rounded-full px-4 py-1.5 text-sm font-semibold text-[#0f1419] transition"
          style="background:#2faf6a"
        >
          Finish Test
        </button>
        <button
          id="retake-btn"
          type="button"
          class="rounded-full border border-[var(--line)] px-4 py-1.5 text-sm font-medium text-[var(--muted)] transition hover:text-[var(--text)] disabled:cursor-not-allowed disabled:opacity-40"
        >
          Take Again
        </button>
      </div>
    </div>
  </main>

  <style>
    .passage .passage-u {
      text-decoration: underline;
      text-decoration-color: var(--text);
      text-underline-offset: 3px;
      color: var(--text);
      font-style: normal;
    }
    .choice.is-correct {
      border-color: #2faf6a;
      background: #2faf6a18;
    }
    .choice.is-correct .choice-key {
      border-color: #2faf6a;
      background: #2faf6a;
      color: #ffffff;
    }
    .choice.is-wrong {
      border-color: #e23a6e;
      background: #e23a6e18;
    }
    .choice.is-wrong .choice-key {
      border-color: #e23a6e;
      background: #e23a6e;
      color: #ffffff;
    }
    .question.answered .choice:not(.is-correct):not(.is-wrong) {
      opacity: 0.55;
    }
  </style>

  <script>
    const COOLDOWN_MS = 5 * 60 * 60 * 1000; // 5 hours

    const mainEl = document.querySelector<HTMLElement>('main')!;
    const subject = mainEl.dataset.subject!;
    const STORAGE_KEY = `preact9_done_${subject}`;

    const questions = Array.from(document.querySelectorAll<HTMLElement>('.question'));
    const progressEl = document.getElementById('progress')!;
    const scoreEl = document.getElementById('score')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const retakeBtn = document.getElementById('retake-btn') as HTMLButtonElement;
    const cooldownBanner = document.getElementById('cooldown-banner')!;
    const cooldownTimeEl = document.getElementById('cooldown-time')!;

    let answered = 0;
    let score = 0;

    function getRemainingMs(): number {
      const ts = localStorage.getItem(STORAGE_KEY);
      if (!ts) return 0;
      return Math.max(0, COOLDOWN_MS - (Date.now() - Number(ts)));
    }

    function isInCooldown(): boolean {
      return getRemainingMs() > 0;
    }

    function formatTime(ms: number): string {
      const totalSec = Math.ceil(ms / 1000);
      const h = Math.floor(totalSec / 3600);
      const m = Math.floor((totalSec % 3600) / 60);
      const s = totalSec % 60;
      if (h > 0) return `${h}h ${m}m`;
      if (m > 0) return `${m}m ${s}s`;
      return `${s}s`;
    }

    function lockChoices() {
      document.querySelectorAll<HTMLButtonElement>('.choice').forEach((b) => {
        b.disabled = true;
      });
    }

    function unlockChoices() {
      document.querySelectorAll<HTMLButtonElement>('.choice').forEach((b) => {
        b.disabled = false;
      });
    }

    function resetTest() {
      answered = 0;
      score = 0;
      submitBtn.classList.add('hidden');
      questions.forEach((q) => {
        q.classList.remove('answered');
        q.querySelectorAll('.choice').forEach((c) =>
          c.classList.remove('is-correct', 'is-wrong')
        );
        q.querySelector('.explanation')?.classList.add('hidden');
      });
      updateStatus();
    }

    function startCooldownBanner() {
      cooldownBanner.classList.remove('hidden');
      submitBtn.classList.add('hidden');
      retakeBtn.disabled = true;

      function tick() {
        const rem = getRemainingMs();
        if (rem <= 0) {
          cooldownBanner.classList.add('hidden');
          retakeBtn.disabled = false;
          retakeBtn.textContent = 'Take Again';
          unlockChoices();
          localStorage.removeItem(STORAGE_KEY);
          return;
        }
        retakeBtn.textContent = `Locked (${formatTime(rem)})`;
        cooldownTimeEl.textContent = formatTime(rem);
        setTimeout(tick, rem < 60_000 ? 1000 : 30_000);
      }
      tick();
    }

    function updateStatus() {
      progressEl.textContent = String(answered);
      scoreEl.textContent = String(score);
      if (answered === questions.length && !isInCooldown()) {
        submitBtn.classList.remove('hidden');
      }
    }

    // On load: if cooldown is active, lock test immediately
    if (isInCooldown()) {
      lockChoices();
      startCooldownBanner();
    }

    // Finish Test button
    submitBtn.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, String(Date.now()));
      lockChoices();
      startCooldownBanner();
    });

    // Question answering
    questions.forEach((q) => {
      const correct = q.dataset.answer;
      const choices = Array.from(q.querySelectorAll<HTMLElement>('.choice'));
      const explanation = q.querySelector<HTMLElement>('.explanation');

      choices.forEach((choice) => {
        choice.addEventListener('click', () => {
          if (q.classList.contains('answered')) return;
          q.classList.add('answered');
          answered++;

          const picked = choice.dataset.choice;
          if (picked === correct) {
            choice.classList.add('is-correct');
            score++;
          } else {
            choice.classList.add('is-wrong');
            const right = choices.find((c) => c.dataset.choice === correct);
            right?.classList.add('is-correct');
          }
          explanation?.classList.remove('hidden');
          updateStatus();
        });
      });
    });

    // Take Again button
    retakeBtn.addEventListener('click', () => {
      if (retakeBtn.disabled) return;
      resetTest();
    });
  </script>
</Base>
